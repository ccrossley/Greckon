{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greckon.dev/schemas/paper-dolls/paper-dolls.schema.json",
  "title": "UnitSpriteCatalog",
  "type": "array",
  "minItems": 1,
  "items": { "$ref": "#/$defs/UnitSprite" },
  "$defs": {
    "Vec2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "number" }
    },
    "UnitSprite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "unitId", "canvasSize", "sprite", "anchor"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "unitId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unit catalog id this sprite replaces the SVG icon for"
        },
        "canvasSize": {
          "type": "integer",
          "minimum": 64,
          "description": "Canonical coordinate space (matches UNIT_ICON_SIZE)"
        },
        "sprite": {
          "type": "string",
          "minLength": 1,
          "description": "Source PNG filename under assets/paper-dolls/"
        },
        "anchor": {
          "$ref": "#/$defs/Vec2",
          "description": "Normalized feet/center point (0–1) for combat placement"
        },
        "scenePrompt": {
          "type": "string",
          "description": "Nano Banana scene description for sprite generation"
        }
      }
    }
  }
}
