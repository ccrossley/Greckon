{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://greckon.dev/schemas/units/units.schema.json",
  "title": "UnitCatalog",
  "type": "array",
  "minItems": 1,
  "items": { "$ref": "#/$defs/UnitDefinition" },
  "$defs": {
    "UnitDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "abilityId",
        "factionId",
        "name",
        "maxHp",
        "attack",
        "defense",
        "speed",
        "sides",
        "attackRange",
        "addAmount",
        "attackType",
        "attackDelayMs",
        "travelTimeMs",
        "movementType",
        "icon"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "factionId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Faction this unit belongs to"
        },
        "abilityId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Combat ability id (references abilities catalog)"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "maxHp": { "type": "integer", "minimum": 1 },
        "attack": { "type": "integer", "minimum": 1 },
        "defense": { "type": "integer", "minimum": 1 },
        "speed": { "type": "integer", "minimum": 1 },
        "sides": { "type": "integer", "minimum": 3 },
        "attackRange": { "type": "number", "minimum": 0.01, "maximum": 1 },
        "addAmount": { "type": "integer", "minimum": 1 },
        "attackType": {
          "type": "string",
          "enum": ["line", "projectile", "instant", "multi"]
        },
        "attackDelayMs": { "type": "integer", "minimum": 0 },
        "damage": { "type": "integer", "minimum": 1 },
        "travelTimeMs": { "type": "integer", "minimum": 0 },
        "movementType": {
          "type": "string",
          "enum": ["float", "hop", "charge"]
        },
        "icon": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Game-icons.net slug (see https://game-icons.net/)"
        },
        "fillColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "Level-1 icon fill. Defaults to #808080 when omitted."
        },
        "upgradeColorMod": {
          "type": "string",
          "enum": ["spectrum", "hue_shift", "lighten", "saturate"],
          "description": "How fill color evolves from level 1 to 4. Defaults to spectrum when omitted."
        },
        "paperDollId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Optional paper-doll rig id; when set, replaces the SVG icon in combat rendering."
        }
      }
    }
  }
}
